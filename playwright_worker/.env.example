# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
REDIS_URL=rediss://default:password@endpoint.upstash.io:6379

# Captcha Service (for future integration - V1 uses stub)
CAPTCHA_API_KEY=
CAPTCHA_PROVIDER=stub  # stub, 2captcha, etc.

# Worker Configuration
POLL_INTERVAL_SECONDS=30
MAX_RETRIES=3
LOG_LEVEL=INFO

# Optional: Proxy for browser
USE_PROXY=true
PROXY_URL=http://u7744f283557105b7-zone-custom:u7744f283557105b7@ap.proxy.2captcha.com:2334

# For this V1, no other keys needed. Register accounts use generated credentials.

# Browserless Integration (Optional)
# If set, routes Playwright through the self-hosted Browserless cluster for maximum stealth
BROWSERLESS_ENDPOINTS=ws://localhost:3000
BROWSERLESS_TOKEN=your-secret-token-here

# Frozen-tab watchdog timeout (seconds). Default: 600 (10 minutes).
# If a job coroutine does not complete within this time the tab is reloaded and the job is retried.
FROZEN_TAB_TIMEOUT_SECONDS=600


DEFAULT_BACKLINK_LIMIT=50
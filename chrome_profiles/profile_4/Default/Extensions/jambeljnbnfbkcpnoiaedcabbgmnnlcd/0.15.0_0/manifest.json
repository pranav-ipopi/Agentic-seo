{
   "action": {
      "default_icon": {
         "16": "icon-16x16.png",
         "32": "icon-32x32.png"
      },
      "default_title": "Record"
   },
   "background": {
      "service_worker": "background.js",
      "type": "module"
   },
   "commands": {
      "inspect": {
         "description": "Start inspecting",
         "suggested_key": {
            "default": "Shift+Alt+C"
         }
      },
      "record": {
         "description": "Start recording",
         "suggested_key": {
            "default": "Shift+Alt+R"
         }
      }
   },
   "icons": {
      "128": "icon-192x192.png",
      "16": "icon-16x16.png",
      "32": "icon-32x32.png",
      "48": "icon-48x48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Playwright CRX",
   "options_ui": {
      "open_in_tab": false,
      "page": "preferences.html"
   },
   "permissions": [ "debugger", "tabs", "contextMenus", "storage", "sidePanel" ],
   "side_panel": {
      "default_path": "empty.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "0.15.0"
}

# Copy to .env and fill in your values.
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_supabase_service_role_or_anon_key
JOBS_TABLE=jobs

# Windows production defaults
BOOKMARKBOT_BASE_DIR=C:\BookmarkBot
PROFILE_BASE_DIR=C:\BookmarkBot\profiles
LOG_DIR=C:\BookmarkBot\logs

# 5000/day target = about 208 successful jobs/hour.
# Start low, test, then increase based on CPU/RAM and site authorization.
NUM_WORKERS=10
JOBS_PER_BATCH=1000
JOBS_PER_DAY_TARGET=5000
JOB_COOLDOWN=1.5
BROWSER_RESTART_EVERY=150
POLL_SLEEP_SECONDS=300
BATCH_SLEEP_SECONDS=1800

# Start-rate controls. Default global interval is calculated from JOBS_PER_DAY_TARGET.
# 5000/day => 17.28 seconds between global job starts.
# GLOBAL_MIN_JOB_START_INTERVAL=17.28
PER_HOST_MIN_JOB_START_INTERVAL=30
START_JITTER_MAX_SECONDS=2

HEADLESS=false
PAGE_LOAD_TIMEOUT=60
WINDOW_WIDTH=1366
WINDOW_HEIGHT=768
MAX_RETRIES=3

# Optional approved outbound proxy routing.
PROXY_MODE=off
# PROXY_LIST_FILE=C:\BookmarkBot\proxies.txt

# Optional safety allow-list, comma separated. Leave blank to disable.
# ALLOWED_HOSTS=example.com,app.yoursite.com

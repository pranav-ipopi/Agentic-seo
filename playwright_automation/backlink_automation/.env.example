# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Captcha Service (for future integration - V1 uses stub)
CAPTCHA_API_KEY=
CAPTCHA_PROVIDER=stub  # stub, 2captcha, etc.

# Worker Configuration
POLL_INTERVAL_SECONDS=30
MAX_RETRIES=3
LOG_LEVEL=INFO

# Optional: Proxy for browser if needed (future)
# BROWSER_PROXY=http://user:pass@host:port

# For this V1, no other keys needed. Register accounts use generated credentials.